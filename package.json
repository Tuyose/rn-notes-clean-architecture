{
  "name": "rn-notes-clean-architecture",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint src app --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"app/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"app/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "expo": "~56.0.9",
    "expo-constants": "~56.0.17",
